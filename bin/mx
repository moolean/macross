#!/usr/bin/env bash
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" != /* ]]; then
    SOURCE="$DIR/$TARGET"
  else
    SOURCE="$TARGET"
  fi
done
DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
cd "$DIR"
export PYTHONPATH="$DIR:${PYTHONPATH:-}"
exec python3 -m macross.cli "$@"
